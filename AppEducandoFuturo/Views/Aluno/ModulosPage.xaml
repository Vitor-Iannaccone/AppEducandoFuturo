<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppEducandoFuturo.Views.Aluno.ModulosPage"
             Title="Módulos"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto, *">

        <!-- Cabeçalho -->
        <Frame Grid.Row="0"
               BackgroundColor="#2E7D32"
               CornerRadius="0"
               Padding="20"
               HasShadow="True">
            <Label Text="📚 Módulos Disponíveis"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="White"/>
        </Frame>

        <!-- Lista de Módulos -->
        <CollectionView Grid.Row="1"
                        x:Name="CollectionModulos"
                        Margin="10"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="White"
                           CornerRadius="12"
                           Padding="15"
                           Margin="0,5"
                           HasShadow="True">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnModuloTapped" CommandParameter="{Binding .}"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="5">
                            <Label Text="{Binding Titulo}"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="#212121"/>
                            <Label Text="{Binding Descricao}"
                                   FontSize="13"
                                   TextColor="#757575"/>
                            <Label Text="{Binding Tema}"
                                   FontSize="12"
                                   TextColor="#2E7D32"
                                   FontAttributes="Italic"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                    <Label Text="📭"
                           FontSize="48"
                           HorizontalOptions="Center"/>
                    <Label Text="Nenhum módulo disponível ainda."
                           FontSize="15"
                           TextColor="#757575"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

    </Grid>

</ContentPage>