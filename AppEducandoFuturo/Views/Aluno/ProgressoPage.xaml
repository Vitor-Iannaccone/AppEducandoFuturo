<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppEducandoFuturo.Views.Aluno.ProgressoPage"
             Title="Meu Progresso"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto, Auto, *">

        <!-- Cabeçalho -->
        <Frame Grid.Row="0"
               BackgroundColor="#2E7D32"
               CornerRadius="0"
               Padding="20"
               HasShadow="True">
            <Label Text="📊 Meu Progresso"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="White"/>
        </Frame>

        <!-- Pontuação Total -->
        <Frame Grid.Row="1"
               BackgroundColor="White"
               CornerRadius="12"
               Padding="20"
               Margin="10"
               HasShadow="True">
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="15">
                <Label Text="⭐" FontSize="30"/>
                <VerticalStackLayout>
                    <Label Text="Pontuação Total"
                           FontSize="13"
                           TextColor="#757575"/>
                    <Label x:Name="LabelPontuacaoTotal"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#2E7D32"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Frame>

        <!-- Lista de Progresso por Módulo -->
        <CollectionView Grid.Row="2"
                        x:Name="CollectionProgresso"
                        Margin="10"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="White"
                           CornerRadius="12"
                           Padding="15"
                           Margin="0,5"
                           HasShadow="True">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding ModuloNome}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#212121"/>
                            <ProgressBar Progress="{Binding ProgressoPercent}"
                                         ProgressColor="#2E7D32"/>
                            <Label Text="{Binding PontuacaoTexto}"
                                   FontSize="13"
                                   TextColor="#757575"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                    <Label Text="📭" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="Nenhuma atividade realizada ainda."
                           FontSize="15"
                           TextColor="#757575"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

    </Grid>

</ContentPage>