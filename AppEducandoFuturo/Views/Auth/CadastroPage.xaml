<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppEducandoFuturo.Views.Auth.CadastroPage"
             Title="Cadastro"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <!-- Título -->
            <Label Text="Criar Conta"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#2E7D32"/>

            <Label Text="Preencha seus dados para continuar"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="#757575"/>

            <!-- Campo Nome -->
            <Entry x:Name="EntryNome"
                   Placeholder="Nome completo"
                   BackgroundColor="White"
                   TextColor="#212121"/>

            <!-- Campo Email -->
            <Entry x:Name="EntryEmail"
                   Placeholder="E-mail"
                   Keyboard="Email"
                   BackgroundColor="White"
                   TextColor="#212121"/>

            <!-- Campo Senha -->
            <Entry x:Name="EntrySenha"
                   Placeholder="Senha"
                   IsPassword="True"
                   BackgroundColor="White"
                   TextColor="#212121"/>

            <!-- Campo Confirmar Senha -->
            <Entry x:Name="EntryConfirmarSenha"
                   Placeholder="Confirmar senha"
                   IsPassword="True"
                   BackgroundColor="White"
                   TextColor="#212121"/>

            <!-- Seleção de tipo de usuário -->
            <Label Text="Tipo de usuário:"
                   FontSize="13"
                   TextColor="#757575"/>

            <Picker x:Name="PickerTipo"
                    Title="Selecione o tipo"
                    BackgroundColor="White"
                    TextColor="#212121">
                <Picker.Items>
                    <x:String>Aluno</x:String>
                    <x:String>Educador</x:String>
                </Picker.Items>
            </Picker>

            <!-- Mensagem de erro/sucesso -->
            <Label x:Name="LabelMensagem"
                   FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="False"/>

            <!-- Botão Cadastrar -->
            <Button Text="Cadastrar"
                    Clicked="OnCadastrarClicked"
                    BackgroundColor="#2E7D32"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="50"/>

            <!-- Link para Login -->
            <Label Text="Já tem conta? Faça login"
                   FontSize="13"
                   HorizontalOptions="Center"
                   TextColor="#2E7D32"
                   TextDecorations="Underline">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLoginTapped"/>
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>