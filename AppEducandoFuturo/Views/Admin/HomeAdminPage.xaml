<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppEducandoFuturo.Views.Admin.HomeAdminPage"
             Title="Painel Admin"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Cabeçalho -->
            <Frame BackgroundColor="#4A148C" CornerRadius="12" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="5">
                    <Label x:Name="LabelSaudacao"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"/>
                    <Label Text="Painel do Administrador"
                           FontSize="14"
                           TextColor="#E1BEE7"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Card Gerenciar Usuários -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="20" HasShadow="True">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGerenciarUsuariosTapped"/>
                </Frame.GestureRecognizers>
                <HorizontalStackLayout Spacing="15">
                    <Label Text="👥" FontSize="36"/>
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="Gerenciar Usuários"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#212121"/>
                        <Label Text="Visualizar e remover usuários"
                               FontSize="13"
                               TextColor="#757575"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Frame>

            <!-- Card Relatórios -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="20" HasShadow="True">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnRelatoriosTapped"/>
                </Frame.GestureRecognizers>
                <HorizontalStackLayout Spacing="15">
                    <Label Text="📈" FontSize="36"/>
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="Relatórios"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#212121"/>
                        <Label Text="Acompanhar desempenho dos alunos"
                               FontSize="13"
                               TextColor="#757575"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Frame>

            <!-- Card Notificações -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="20" HasShadow="True">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotificacoesTapped"/>
                </Frame.GestureRecognizers>
                <HorizontalStackLayout Spacing="15">
                    <Label Text="🔔" FontSize="36"/>
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="Notificações"
                   FontSize="18" FontAttributes="Bold" TextColor="#212121"/>
                        <Label Text="Enviar notificações aos usuários"
                   FontSize="13" TextColor="#757575"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Frame>

            <!-- Botão Sair -->
            <Button Text="Sair"
                    Clicked="OnSairClicked"
                    BackgroundColor="#D32F2F"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="45"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>